generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum AttendanceStatus {
  PRESENT
  ABSENT_SERIOUS
  ABSENT_NON_SERIOUS
  SCHOOL_CLOSED
  CLASS_CANCELED
  TRIAL
}

enum SalaryType {
  PERCENTAGE
  FIXED
}

enum ClassRole {
  TEACHER
  ASSISTANT
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

enum LedgerType {
  INVOICE
  PAYMENT
  CREDIT
  DEBIT
  ADJUSTMENT
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
}

enum RecurringInterval {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  TRANSFERRED
  DROPPED
}

enum PaymentMethod {
  CASH
  TRANSFER
}

enum TeacherLedgerType {
  ACCRUAL
  PAYOUT
  ADVANCE_DEDUCTION
  FINE_DEDUCTION
}

//////////////////////
// USERS & ROLES
//////////////////////

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String
  role      UserRole
  createdAt DateTime @default(now())

  teacher   Teacher?
}

//////////////////////
// CORE ENTITIES
//////////////////////

model Student {
  id             String    @id @default(uuid())
  studentNumber  Int       @unique @default(autoincrement())
  fullName       String
  phone          String?
  parentName     String?
  parentTitle    String?
  parentPhone    String?
  startDate      DateTime
  nextPaymentDue DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  classes    StudentClass[]
  attendance Attendance[]
  invoices   Invoice[]
  ledger     Ledger[]
}

model Teacher {
  id        String   @id @default(uuid())
  fullName  String
  createdAt DateTime @default(now())

  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])

  classes              ClassTeacher[]
  attendance           Attendance[]
  earnings             TeacherEarnings[]
  fines                TeacherFine[]
  expenses             Expense[]
  ledgerEntries        TeacherLedger[]
  overridesAsOriginal  ClassTeacherOverride[] @relation("OverrideOriginal")
  overridesAsSubstitute ClassTeacherOverride[] @relation("OverrideSubstitute")
  assistantAttendanceRecorded AssistantAttendance[] @relation("AssistantAttendanceRecordedBy")
}

model Room {
  id        String   @id @default(uuid())
  name      String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())

  classes Class[]
}

model Class {
  id            String   @id @default(uuid())
  classNumber   Int      @unique @default(autoincrement())
  name          String
  roomId        String?
  room          Room?    @relation(fields: [roomId], references: [id])
  startHour     Int      @default(9)
  startMinute   Int      @default(0)
  endHour       Int      @default(10)
  endMinute     Int      @default(0)
  pricePerMonth Float
  scheduleDays  String[] @default([])
  createdAt     DateTime @default(now())

  students          StudentClass[]
  teachers          ClassTeacher[]
  attendance        Attendance[]
  closures          SchoolClosure[]
  teacherOverrides  ClassTeacherOverride[]
  invoiceLines      InvoiceLine[]
  ledgerEntries     Ledger[]
  teacherLedgerEntries TeacherLedger[]
}

//////////////////////
// RELATION TABLES
//////////////////////

model StudentClass {
  id         String           @id @default(uuid())
  studentId  String
  classId    String
  startDate  DateTime
  endDate    DateTime?
  customRate Float?           // override class price for this student (item 5)
  isFree     Boolean          @default(false)  // attends free; teacher still paid from admin pool (item 6)
  score      Float?           // academic score assigned by teacher (1–5 in 0.5 steps)
  status     EnrollmentStatus @default(ACTIVE)

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])
}

model ClassTeacher {
  id          String     @id @default(uuid())
  classId     String
  teacherId   String
  role        ClassRole  @default(TEACHER)
  salaryType  SalaryType @default(PERCENTAGE)
  percentage  Float      @default(0)
  fixedAmount Float?

  class                Class                 @relation(fields: [classId], references: [id])
  teacher              Teacher               @relation(fields: [teacherId], references: [id])
  assistantAttendance  AssistantAttendance[]
}

model ClassTeacherOverride {
  id                  String   @id @default(uuid())
  classId             String
  date                DateTime
  originalTeacherId   String
  substituteTeacherId String
  reason              String?
  createdAt           DateTime @default(now())

  class             Class    @relation(fields: [classId], references: [id])
  originalTeacher   Teacher  @relation("OverrideOriginal",     fields: [originalTeacherId],   references: [id])
  substituteTeacher Teacher  @relation("OverrideSubstitute",   fields: [substituteTeacherId], references: [id])
}

//////////////////////
// ASSISTANT ATTENDANCE
//////////////////////

model AssistantAttendance {
  id                 String   @id @default(uuid())
  classTeacherId     String
  date               DateTime
  present            Boolean  @default(false)
  recordedByTeacherId String?
  createdAt          DateTime @default(now())

  classTeacher     ClassTeacher @relation(fields: [classTeacherId], references: [id])
  recordedByTeacher Teacher?    @relation("AssistantAttendanceRecordedBy", fields: [recordedByTeacherId], references: [id])
}

//////////////////////
// ATTENDANCE
//////////////////////

model Attendance {
  id        String           @id @default(uuid())
  studentId String
  classId   String
  teacherId String?
  date      DateTime
  status    AttendanceStatus
  isTrial   Boolean          @default(false)
  createdAt DateTime         @default(now())

  student Student  @relation(fields: [studentId], references: [id])
  class   Class    @relation(fields: [classId], references: [id])
  teacher Teacher? @relation(fields: [teacherId], references: [id])
}

//////////////////////
// BILLING
//////////////////////

model Invoice {
  id                String        @id @default(uuid())
  invoiceNumber     Int           @unique @default(autoincrement())
  studentId         String
  periodStart       DateTime
  periodEnd         DateTime
  totalAmount       Float
  creditApplied     Float
  finalAmount       Float
  status            InvoiceStatus @default(PENDING)
  originalInvoiceId String?
  returnedAmount    Float?
  createdAt         DateTime      @default(now())

  student         Student   @relation(fields: [studentId], references: [id])
  lines           InvoiceLine[]
  originalInvoice Invoice?  @relation("InvoiceCorrections", fields: [originalInvoiceId], references: [id])
  corrections     Invoice[] @relation("InvoiceCorrections")
}

model InvoiceLine {
  id        String   @id @default(uuid())
  invoiceId String
  classId   String
  amount    Float
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])
}

model Ledger {
  id            String         @id @default(uuid())
  studentId     String
  type          LedgerType
  amount        Float
  classId       String?
  paymentMethod PaymentMethod?
  // Polymorphic: points at an Invoice.id (referenceType "Invoice", used by
  // invoice PAYMENT/ADJUSTMENT rows), an Attendance.id (attendance DEBITs),
  // or a StudentClass.id (early-drop/transfer CREDITs) depending on
  // referenceType/type — intentionally has no DB-level foreign key since it
  // can't reference a single table.
  referenceId   String?
  referenceType String?
  createdAt     DateTime       @default(now())

  student Student  @relation(fields: [studentId], references: [id])
  class   Class?   @relation(fields: [classId], references: [id])
}

//////////////////////
// TEACHER PAYMENTS
//////////////////////

model TeacherEarnings {
  id            String         @id @default(uuid())
  teacherId     String
  month         Int
  year          Int
  totalAmount   Float
  isPaid        Boolean        @default(false)
  paymentMethod PaymentMethod? @default(CASH)
  isSplit       Boolean        @default(false)
  cashAmount    Float?
  transferAmount Float?
  createdAt     DateTime       @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id])
}

model TeacherLedger {
  id          String            @id @default(uuid())
  teacherId   String
  classId     String?
  date        DateTime?
  type        TeacherLedgerType
  amount      Float
  referenceId String?
  createdAt   DateTime          @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id])
  class   Class?  @relation(fields: [classId], references: [id])
}

model TeacherFine {
  id        String   @id @default(uuid())
  teacherId String
  classId   String?
  date      DateTime
  amount    Float
  reason    String?
  isWaived  Boolean  @default(false)
  createdAt DateTime @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id])
}

//////////////////////
// ACCOUNTING
//////////////////////

model ExpenseType {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  expenses          Expense[]
  recurringExpenses RecurringExpense[]
}

model Expense {
  id             String        @id @default(uuid())
  title          String
  amount         Float
  date           DateTime
  category       String?
  note           String?
  expenseTypeId  String?
  expenseType    ExpenseType?  @relation(fields: [expenseTypeId], references: [id])
  teacherId      String?
  teacher        Teacher?      @relation(fields: [teacherId], references: [id])
  deductMonth    Int?
  deductYear     Int?
  isDeducted     Boolean       @default(false)
  paymentMethod  PaymentMethod @default(CASH)
  isSplit        Boolean       @default(false)
  cashAmount     Float?
  transferAmount Float?
  createdAt      DateTime      @default(now())
}

//////////////////////
// SCHOOL CLOSURES
//////////////////////

model SchoolClosure {
  id      String   @id @default(uuid())
  date    DateTime
  classId String?
  reason  String?
  isPaid  Boolean  @default(false)

  class Class? @relation(fields: [classId], references: [id])
}

model RecurringExpense {
  id            String            @id @default(uuid())
  title         String
  amount        Float
  interval      RecurringInterval
  nextDueDate   DateTime
  expenseTypeId String?
  expenseType   ExpenseType?      @relation(fields: [expenseTypeId], references: [id])
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
}

//////////////////////
// AUDIT LOGS
//////////////////////

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  createdAt DateTime @default(now())
}
