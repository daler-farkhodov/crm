# --- Neon (recommended) ---
# In Neon: Dashboard → your project → Connect → copy the Prisma / Node connection strings.
# Use the POOLED URL for DATABASE_URL and the DIRECT (non-pooler) URL for DIRECT_URL so
# `prisma migrate` works. If Neon only shows one URL, paste the same value into both.
#
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.aws.neon.tech/neondb?sslmode=require"

# --- Local Docker (from this repo) ---
# Same value for both when not using a pooler.
DATABASE_URL="postgresql://postgres:postgres@localhost:54332/crm"
DIRECT_URL="postgresql://postgres:postgres@localhost:54332/crm"
